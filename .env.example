# ══════════════════════════════════════════════════════
# ERP PYMES – Archivo de configuración global
# Copia este archivo como .env y rellena los valores
# ══════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────
APP_NAME="ERP PYMEs"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# ── Base de datos MongoDB ──────────────────────────────
# Sustituye USUARIO, PASSWORD y el host por los de tu cluster
DB_CONNECTION=mongodb
DB_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.XXXXX.mongodb.net/
DB_DATABASE=erp_pymes

# Para MongoDB local usar:
# DB_URI=mongodb://127.0.0.1:27017
# DB_DATABASE=erp_pymes

# ── Sesiones ───────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Caché y colas ─────────────────────────────────────
CACHE_STORE=array
QUEUE_CONNECTION=sync

# ── Logs ──────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Almacenamiento ────────────────────────────────────
FILESYSTEM_DISK=local

# ══════════════════════════════════════════════════════
# PRODUCCIÓN (Railway) – cambiar estos valores:
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://web-production-755fc.up.railway.app
#   LOG_CHANNEL=stderr
#   LOG_LEVEL=error
#   SESSION_SECURE_COOKIE=false
# ══════════════════════════════════════════════════════