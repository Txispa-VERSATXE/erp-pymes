{
  "php": {
    "version": "8.3",
    "extensions": ["mongodb", "gd", "zip", "curl", "mbstring", "xml", "intl", "tokenizer", "ctype", "fileinfo", "openssl", "bcmath"]
  },
  "steps": {
    "extensions": {
      "commands": [
        "install-php-extensions mongodb gd zip curl mbstring xml intl tokenizer ctype fileinfo openssl bcmath"
      ]
    }
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT --docroot=public"
  }
}